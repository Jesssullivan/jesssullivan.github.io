{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "typeRoots": ["../../node_modules/@types"],
    "types": ["node", "bun"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "app.ts", "agentuity.config.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
