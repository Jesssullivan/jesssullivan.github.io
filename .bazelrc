common --enable_bzlmod
common --registry=https://raw.githubusercontent.com/tinyland-inc/bazel-registry/main
common --registry=https://bcr.bazel.build
common --experimental_repository_downloader_retries=5
common --http_timeout_scaling=2.0

build --jobs=auto
build --worker_sandboxing
build --disk_cache=~/.cache/bazel-jesssullivan-github-io
build --show_timestamps
build --remote_cache_async
build --experimental_guard_against_concurrent_changes
build --allow_unresolved_symlinks
build --action_env=NODE_OPTIONS=--max-old-space-size=4096
build --action_env=SOURCE_DATE_EPOCH=1710000000
build --action_env=TZ=UTC

test --test_output=errors
test --test_timeout=120,600,1800,3600
# Pass the browser path through from the lane (executor images ship
# /bin/chromium; the dind runner provisions one in ci.yml and exports
# GF_RBE_CHROMIUM_EXECUTABLE). No hardcoded value: an absent var lets
# the run-*-bazel.mjs candidate scan handle system chromium paths.
test --test_env=GF_RBE_CHROMIUM_EXECUTABLE

build:local --disk_cache=~/.cache/bazel-jesssullivan-github-io

build:ci --color=no
build:ci --curses=no
build:ci --noshow_loading_progress
build:ci --disk_cache=
common:ci --lockfile_mode=error
test:ci --test_output=errors

build:ci-remote-base --config=ci
build:ci-remote-base --remote_upload_local_results=true
build:ci-remote-base --remote_download_minimal
build:ci-remote-base --remote_timeout=60

build:ci-cached --config=ci-remote-base
build:ci-cached --remote_cache_compression
# Shared-cache actions execute inside a 2-CPU, 4 GiB ARC runner container.
# Bound both action parallelism and per-process Node heap so one local action
# plus Bazel overhead remains inside that hard memory limit. Executor-backed
# proofs retain their separately managed capacity.
build:ci-cached --jobs=1
build:ci-cached --action_env=NODE_OPTIONS=--max-old-space-size=1024
# Browser-backed test actions execute inside the same 4 GiB ARC pod in this mode.
# Keep them serial so concurrent Chromium processes cannot OOM the runner.
test:ci-cached --local_test_jobs=1

build:executor-backed --config=ci-remote-base
build:executor-backed --action_env=HOME=/var/lib/gf-reapi-cell/home
build:executor-backed --action_env=TMPDIR=/tmp
build:executor-backed --action_env=XDG_CACHE_HOME=/var/lib/gf-reapi-cell/xdg-cache
build:executor-backed --action_env=XDG_CONFIG_HOME=/var/lib/gf-reapi-cell/xdg-config
build:executor-backed --action_env=XDG_DATA_HOME=/var/lib/gf-reapi-cell/xdg-data
build:executor-backed --spawn_strategy=remote,worker,sandboxed,local
build:cache-readonly --remote_upload_local_results=false
build:no-remote-cache --remote_cache=

# Back-compat profile name used by GloriousFlywheel proof harnesses.
build:gloriousflywheel --config=ci-cached
test:gloriousflywheel --config=ci-cached

try-import %workspace%/user.bazelrc

try-import %workspace%/.bazelrc.flywheel
