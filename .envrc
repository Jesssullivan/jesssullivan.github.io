# direnv configuration for SvelteKit blog development
# Usage: direnv allow

# Load .env if exists
dotenv_if_exists

# Load the bounded GloriousFlywheel fallback profile if present. This file is
# gitignored; endpoint/auth authority should normally come from the managed
# fleet profile.
[ -f .env.flywheel.local ] && dotenv .env.flywheel.local

# Keep the local shell's declared substrate mode aligned with attached endpoints.
if [ -n "${BAZEL_REMOTE_EXECUTOR:-}" ]; then
  export GF_BAZEL_SUBSTRATE_MODE=executor-backed
elif [ -n "${BAZEL_REMOTE_CACHE:-}" ]; then
  export GF_BAZEL_SUBSTRATE_MODE=shared-cache-backed
else
  export GF_BAZEL_SUBSTRATE_MODE=compatibility-local-only
fi

# Add scripts to PATH
PATH_add scripts

# Watch for dependency changes
watch_file package.json
watch_file package-lock.json

export NODE_ENV="${NODE_ENV:-development}"
