{
	"name": "jesssullivan.github.io",
	"version": "0.0.1",
	"license": "CC0-1.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"prebuild": "tsx scripts/generate-search-index.mts && tsx scripts/optimize-images.mts && tsx scripts/render-mermaid.mts && tsx scripts/generate-blog-stats.mts && tsx scripts/generate-tag-graph.mts && tsx scripts/generate-photo-gallery.mts",
		"build": "vite build",
		"postbuild": "tsx scripts/generate-redirects.mts && pagefind --site build",
		"test:redirects": "npm run build && tsx scripts/validate-redirects.mts",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint src/lib packages/blog-agent/src packages/blog-agent/test --max-warnings 0",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@mermaid-js/mermaid-cli": "^11.12.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@tummycrypt/vite-plugin-a11y": "^0.2.1",
		"@tummycrypt/vite-plugin-skeleton-colors": "^0.2.1",
		"@types/node": "^25.2.3",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"pagefind": "^1.5.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"rollup-plugin-visualizer": "^6.0.5",
		"serve": "^14.2.5",
		"sharp": "^0.34.5",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.5",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.2",
		"@vitest/coverage-v8": "^4.1.4",
		"vite": "npm:rolldown-vite@^7.3.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@fontsource/crimson-pro": "^5.2.8",
		"@fontsource/fira-code": "^5.2.7",
		"@fontsource/inter": "^5.2.8",
		"@fontsource/raleway": "^5.2.8",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"@tummycrypt/tinyvectors": "^0.2.3",
		"flexsearch": "^0.8.212",
		"mdsvex": "^0.12.7",
		"mermaid": "^11.12.2",
		"shiki": "^4.0.2",
		"tailwindcss": "^4.2.2"
	},
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"overrides": {
		"vite": "npm:rolldown-vite@^7.3.1"
	}
}
